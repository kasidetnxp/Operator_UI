        <mxCell id="50" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;fontColor=#1a1a2e;fontFamily=Segoe UI;" value="FPC Management System — Role-Based Permission Workflow (Onion Model)" vertex="1">
